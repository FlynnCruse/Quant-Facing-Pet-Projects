{
  "name": "market-data-dissemination-simulator",
  "version": "1.0.0",
  "description": "A sophisticated client-server application demonstrating middleware concepts for real-time market data",
  "scripts": {
    "start": "node start.js",
    "build": "dotnet build",
    "start:server": "dotnet run --project Server",
    "start:client": "dotnet run --project Client",
    "start:api": "cd api && node index.js",
    "start:frontend": "cd frontend && npm run dev"
  },
  "dependencies": {
    "lightweight-charts": "^5.0.6"
  }
}
